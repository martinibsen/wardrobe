# Required for the Wardrobe email signup endpoint (/api/signup).
# Create a server API key in Loops: https://app.loops.so/settings?page=api
# Also create a mailing list named "wardrobe" before first signup.
LOOPS_API_KEY=

# Optional: PostHog analytics. When set, PostHog loads on pages where
# the visitor has accepted the cookie banner (localStorage key
# "wardrobe-cookie-consent" === "accepted"). Without a key, analytics
# stay off regardless of consent.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
