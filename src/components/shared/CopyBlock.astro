---
import { codeToHtml } from "shiki";

interface Props {
    code: string;
    prompt: string;
    theme: string;
    label?: string;
    component?: string;
    system?: string;
    defaultTab?: "code" | "prompt" | "theme";
}

const {
    code,
    prompt,
    theme,
    label,
    component = "",
    system = "hyper",
    defaultTab = "prompt",
} = Astro.props;

const codeHtml = await codeToHtml(code, {
    lang: "tsx",
    theme: "github-dark-default",
});
const promptHtml = `<pre><code>${escapeHtml(prompt)}</code></pre>`;
const themeHtml = await codeToHtml(theme, {
    lang: "css",
    theme: "github-dark-default",
});

function escapeHtml(s: string) {
    return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
}
---

<div
    class="copyblock"
    data-component={component}
    data-system={system}
    data-default-tab={defaultTab}
>
    {label && <div class="copyblock__label">{label}</div>}
    <div class="copyblock__head">
        <div class="copyblock__tabs" role="tablist">
            <button
                type="button"
                role="tab"
                class="copyblock__tab"
                data-tab="code"
                aria-selected="false"
            >
                CODE
            </button>
            <button
                type="button"
                role="tab"
                class="copyblock__tab"
                data-tab="prompt"
                aria-selected="false"
            >
                PROMPT
            </button>
            <button
                type="button"
                role="tab"
                class="copyblock__tab"
                data-tab="theme"
                aria-selected="false"
            >
                THEME
            </button>
        </div>
        <button type="button" class="copyblock__copy" aria-label="Copy to clipboard">
            <span class="copyblock__copy-label">COPY</span>
        </button>
    </div>

    <div class="copyblock__pane" data-pane="code">
        <Fragment set:html={codeHtml} />
        <textarea class="copyblock__source" data-source="code" hidden>{code}</textarea>
    </div>
    <div class="copyblock__pane" data-pane="prompt">
        <Fragment set:html={promptHtml} />
        <textarea class="copyblock__source" data-source="prompt" hidden>{prompt}</textarea>
    </div>
    <div class="copyblock__pane" data-pane="theme">
        <Fragment set:html={themeHtml} />
        <textarea class="copyblock__source" data-source="theme" hidden>{theme}</textarea>
    </div>
</div>

<style is:global>
    .copyblock {
        border: 1px solid var(--color-fg, #3a1e1e);
        border-radius: var(--radius-md, 12px);
        background: #0d1117;
        margin: 16px 0 32px;
        overflow: hidden;
    }
    .copyblock__label {
        background: var(--color-surface, #fff);
        color: var(--color-fg, #3a1e1e);
        font-family: var(--font-display, "Anton", sans-serif);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 12px;
        padding: 10px 16px;
        border-bottom: 1px solid var(--color-fg, #3a1e1e);
    }
    .copyblock__head {
        display: flex;
        justify-content: space-between;
        align-items: stretch;
        background: var(--color-surface, #fff);
        border-bottom: 1px solid var(--color-fg, #3a1e1e);
    }
    .copyblock__tabs {
        display: flex;
        gap: 0;
    }
    .copyblock__tab {
        font-family: var(--font-display, "Anton", sans-serif);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 12px;
        padding: 12px 18px;
        border: none;
        background: transparent;
        color: var(--color-fg, #3a1e1e);
        cursor: pointer;
        border-right: 1px solid var(--color-fg, #3a1e1e);
        transition: background 100ms ease, color 100ms ease;
        line-height: 1;
    }
    .copyblock__tab[aria-selected="true"] {
        background: var(--color-fg, #3a1e1e);
        color: var(--color-bg, #efff71);
    }
    .copyblock__copy {
        font-family: var(--font-display, "Anton", sans-serif);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 12px;
        padding: 12px 18px;
        border: none;
        border-left: 1px solid var(--color-fg, #3a1e1e);
        background: var(--color-bg, #efff71);
        color: var(--color-fg, #3a1e1e);
        cursor: pointer;
        line-height: 1;
        transition: background 100ms ease, color 100ms ease;
    }
    .copyblock__copy:hover {
        background: var(--color-fg, #3a1e1e);
        color: var(--color-bg, #efff71);
    }
    .copyblock__copy.is-copied {
        background: var(--color-success, #c3ff8b);
        color: var(--color-fg, #3a1e1e);
    }
    .copyblock__pane {
        display: none;
        max-height: 480px;
        overflow: auto;
    }
    .copyblock__pane[data-active="true"] {
        display: block;
    }
    .copyblock__pane pre {
        margin: 0;
        padding: 18px 20px !important;
        font-family: var(--font-mono, "JetBrains Mono", ui-monospace, monospace);
        font-size: 12.5px;
        line-height: 1.55;
        background: #0d1117 !important;
        white-space: pre;
    }
    .copyblock__pane pre code {
        font-family: inherit;
    }
    .copyblock__pane[data-pane="prompt"] pre {
        white-space: pre-wrap;
        color: #d6deeb;
    }
    .copyblock__source {
        position: absolute !important;
        left: -9999px !important;
    }

    @media (max-width: 600px) {
        .copyblock__tab,
        .copyblock__copy { padding: 10px 12px; font-size: 11px; }
        .copyblock__pane pre { font-size: 11.5px; padding: 14px 16px !important; }
    }
</style>

<script>
    function setupCopyBlocks() {
        document.querySelectorAll<HTMLElement>(".copyblock").forEach((block) => {
            if (block.dataset.bound === "true") return;
            block.dataset.bound = "true";

            const tabs = block.querySelectorAll<HTMLButtonElement>(".copyblock__tab");
            const panes = block.querySelectorAll<HTMLElement>(".copyblock__pane");
            const copyBtn = block.querySelector<HTMLButtonElement>(".copyblock__copy");
            const copyLabel = block.querySelector<HTMLElement>(".copyblock__copy-label");
            const defaultTab = (block.dataset.defaultTab ?? "prompt") as
                | "code"
                | "prompt"
                | "theme";

            function activate(tab: "code" | "prompt" | "theme") {
                tabs.forEach((t) => {
                    const isActive = t.dataset.tab === tab;
                    t.setAttribute("aria-selected", String(isActive));
                });
                panes.forEach((p) => {
                    p.dataset.active = String(p.dataset.pane === tab);
                });
                block.dataset.activeTab = tab;
            }

            tabs.forEach((t) => {
                t.addEventListener("click", () => {
                    activate(t.dataset.tab as "code" | "prompt" | "theme");
                });
            });

            copyBtn?.addEventListener("click", async () => {
                const active = (block.dataset.activeTab ?? defaultTab) as string;
                const source = block.querySelector<HTMLTextAreaElement>(
                    `.copyblock__source[data-source="${active}"]`,
                );
                if (!source) return;
                try {
                    await navigator.clipboard.writeText(source.value);
                } catch {
                    const tmp = document.createElement("textarea");
                    tmp.value = source.value;
                    document.body.appendChild(tmp);
                    tmp.select();
                    document.execCommand("copy");
                    document.body.removeChild(tmp);
                }
                if (copyLabel) {
                    const original = copyLabel.textContent ?? "COPY";
                    copyLabel.textContent = "COPIED ✓";
                    copyBtn.classList.add("is-copied");
                    setTimeout(() => {
                        copyLabel.textContent = original;
                        copyBtn.classList.remove("is-copied");
                    }, 2000);
                }
                const evt = new CustomEvent("wardrobe:copy", {
                    bubbles: true,
                    detail: {
                        component: block.dataset.component ?? "",
                        system: block.dataset.system ?? "hyper",
                        target: active,
                    },
                });
                block.dispatchEvent(evt);
            });

            activate(defaultTab);
        });
    }

    setupCopyBlocks();
    document.addEventListener("astro:page-load", setupCopyBlocks);
</script>
