---
/**
 * CookieBanner — bottom-of-viewport cookie consent.
 *
 * Persists choice in localStorage under "wardrobe-cookie-consent" with
 * values "accepted" or "declined". Banner self-hides after a choice.
 * Dispatches a "wardrobe-consent" CustomEvent so the PostHog loader in
 * Layout.astro can pick up an in-session opt-in without a reload.
 */
---

<div class="cookie-banner" data-cookie-banner hidden role="dialog" aria-label="Cookie consent">
    <p class="cookie-banner__copy">
        We use PostHog for anonymous analytics. No personal data sold.
        <a href="/privacy">Privacy policy →</a>
    </p>
    <div class="cookie-banner__actions">
        <button type="button" class="cookie-banner__decline" data-cookie-decline>
            Just essentials
        </button>
        <button type="button" class="cookie-banner__accept" data-cookie-accept>
            Accept
        </button>
    </div>
</div>

<style>
    .cookie-banner {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 90;
        background: #ffffff;
        border-top: 1px solid #e5e5e5;
        padding: 14px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        flex-wrap: wrap;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
            "Helvetica Neue", Arial, sans-serif;
        font-size: 13px;
        line-height: 1.5;
        color: #525252;
        box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.04);
    }
    /* `display: flex` above out-specifies the browser default for [hidden],
       so we must explicitly hide the banner when the attribute is set. */
    .cookie-banner[hidden] { display: none; }
    .cookie-banner__copy {
        margin: 0;
        flex: 1 1 320px;
    }
    .cookie-banner__copy a {
        color: #0a0a0a;
        text-decoration: underline;
    }
    .cookie-banner__copy a:hover { color: #2a2a2a; }
    .cookie-banner__actions {
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .cookie-banner__decline {
        background: none;
        border: none;
        font: inherit;
        color: #525252;
        cursor: pointer;
        padding: 8px 4px;
        text-decoration: underline;
    }
    .cookie-banner__decline:hover { color: #0a0a0a; }
    .cookie-banner__accept {
        background: #0a0a0a;
        color: #ffffff;
        border: none;
        padding: 10px 18px;
        border-radius: 6px;
        font: inherit;
        font-weight: 500;
        cursor: pointer;
        transition: background 120ms ease;
    }
    .cookie-banner__accept:hover { background: #2a2a2a; }
    .cookie-banner__accept:focus-visible,
    .cookie-banner__decline:focus-visible {
        outline: 2px solid #0a0a0a;
        outline-offset: 2px;
    }

    @media (max-width: 540px) {
        .cookie-banner {
            flex-direction: column;
            align-items: stretch;
            gap: 12px;
            padding: 14px 18px;
        }
        .cookie-banner__actions { justify-content: flex-end; }
    }
</style>

<script is:inline>
    (function () {
        const STORAGE_KEY = "wardrobe-cookie-consent";
        const banner = document.querySelector("[data-cookie-banner]");
        if (!banner) return;

        let consent = null;
        try {
            consent = localStorage.getItem(STORAGE_KEY);
        } catch (_) { /* localStorage may be unavailable */ }

        if (consent === "accepted" || consent === "declined") {
            return;
        }

        banner.hidden = false;

        function setConsent(value) {
            try {
                localStorage.setItem(STORAGE_KEY, value);
            } catch (_) { /* noop */ }
            banner.hidden = true;
            window.dispatchEvent(
                new CustomEvent("wardrobe-consent", { detail: { consent: value } })
            );
        }

        const acceptBtn = banner.querySelector("[data-cookie-accept]");
        const declineBtn = banner.querySelector("[data-cookie-decline]");
        if (acceptBtn) acceptBtn.addEventListener("click", function () { setConsent("accepted"); });
        if (declineBtn) declineBtn.addEventListener("click", function () { setConsent("declined"); });
    })();
</script>
