---
interface Props {
    name: string;
    title?: string;
    blurb?: string;
}

const { name, title, blurb } = Astro.props;
const heading = title ?? name;
---

<section class="showcase" id={`hyp-${name.toLowerCase()}`}>
    <header class="showcase__head">
        <h3 class="showcase__title">{heading}.</h3>
        {blurb && <p class="showcase__blurb">{blurb}</p>}
    </header>

    <div class="showcase__preview">
        <slot name="preview" />
    </div>

    <div class="showcase__copy">
        <slot name="copy" />
    </div>
</section>

<style>
    .showcase {
        border-top: 1px solid var(--color-fg);
        padding: 56px 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
    }
    .showcase__head {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .showcase__title {
        font-family: var(--font-display);
        text-transform: uppercase;
        font-size: 56px;
        line-height: 0.85;
        letter-spacing: -0.02em;
        margin: 0;
    }
    .showcase__blurb {
        font-family: var(--font-body);
        font-size: 16px;
        line-height: 1.5;
        margin: 0;
        max-width: 540px;
        opacity: 0.85;
    }
    .showcase__preview {
        background: var(--color-surface);
        border: 1px solid var(--color-fg);
        border-radius: var(--radius-md);
        padding: 40px;
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        align-items: center;
        min-height: 140px;
    }
    .showcase__copy {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    @media (max-width: 600px) {
        .showcase { padding: 36px 0; gap: 24px; }
        .showcase__title { font-size: 40px; }
        .showcase__preview { padding: 24px; gap: 16px; }
    }
</style>
