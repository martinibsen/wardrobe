---
/**
 * NodesignChrome — the always-on chrome for Nodesign habitat pages.
 *
 * Provides:
 *   1. Magnetic-hover wiring — any element with class "nds-magnetic"
 *      gets its inner <span> translated by mouse position * data-strength.
 *   2. Blueprint background SVG (faint geometric guide-lines) at opacity 0.04.
 *
 * Peripherals (top-left brand, top-center focal label, top-right link)
 * are rendered by the parent page using <a class="nds-text nds-peripheral …">,
 * because each habitat page wants different active states. NodesignChrome
 * just provides the magnetic JS that wires them up.
 */
interface Props {
    /** Tag the brand mark (top-left) link */
    brandHref?: string;
    brandLabel?: string;
    /** Hide the brand mark entirely (overview page where the focal point is the headline) */
    hideBrand?: boolean;
}
const {
    brandHref = "/nodesign/essence",
    brandLabel = "Essence",
    hideBrand = false,
} = Astro.props;
---

<!-- Background blueprint SVG (faint, fixed, behind everything) -->
<div class="nds-blueprint" aria-hidden="true">
    <svg viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="currentColor" stroke-width="0.4" fill="none">
            <line x1="0" y1="450" x2="1440" y2="450" />
            <line x1="720" y1="0" x2="720" y2="900" />
            <line x1="0" y1="0" x2="1440" y2="900" />
            <line x1="1440" y1="0" x2="0" y2="900" />
            <circle cx="720" cy="450" r="220" stroke-width="0.3" />
            <circle cx="720" cy="450" r="380" stroke-width="0.2" />
            <rect x="120" y="120" width="1200" height="660" stroke-width="0.4" />
            <line x1="120" y1="240" x2="1320" y2="240" stroke-width="0.2" />
            <line x1="120" y1="660" x2="1320" y2="660" stroke-width="0.2" />
        </g>
    </svg>
</div>

{!hideBrand && (
    <a class="nds-text nds-peripheral nds-magnetic nds-top-left" data-strength="20" href={brandHref}>
        <span>{brandLabel}</span>
    </a>
)}

<!-- The page provides additional peripherals (top-center focal label, top-right link) inline. -->
<slot />

<script is:inline>
    (function () {
        if (typeof window === "undefined") return;

        // Magnetic hover — translates the inner span of any .nds-magnetic
        // element based on cursor position relative to its bounding rect.
        function wireMagnetics() {
            const magnetics = document.querySelectorAll(".nds-magnetic");
            magnetics.forEach(function (elem) {
                if (elem.dataset.ndsWired === "true") return;
                elem.dataset.ndsWired = "true";
                const innerSpan = elem.querySelector("span");
                if (!innerSpan) return;

                elem.addEventListener("mousemove", function (e) {
                    const rect = elem.getBoundingClientRect();
                    const x = e.clientX - rect.left - rect.width / 2;
                    const y = e.clientY - rect.top - rect.height / 2;
                    const strength = parseFloat(elem.dataset.strength || "20");
                    innerSpan.style.transform =
                        "translate(" +
                        (x / rect.width) * strength +
                        "px, " +
                        (y / rect.height) * strength +
                        "px)";
                    innerSpan.style.transition = "transform 0.1s linear";
                });

                elem.addEventListener("mouseleave", function () {
                    innerSpan.style.transform = "translate(0px, 0px)";
                    innerSpan.style.transition =
                        "transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)";
                });
            });
        }
        wireMagnetics();
        // Re-wire if any magnetics get added later (e.g. via SPA-style nav)
        const observer = new MutationObserver(wireMagnetics);
        observer.observe(document.body, { childList: true, subtree: true });
    })();
</script>
