---
import Layout from "../../layouts/Layout.astro";
import EmailSignup from "../../components/shared/EmailSignup.astro";
import InstallGate from "../../components/shared/InstallGate.astro";
import { generateFullInstallPrompt } from "../../utils/generate-prompts";

const prompts = {
    "claude-code": generateFullInstallPrompt("claude-code", "system"),
    v0: generateFullInstallPrompt("v0", "system"),
    lovable: generateFullInstallPrompt("lovable", "system"),
};
---

<Layout
    title="Install System — Wardrobe"
    description="One paste. 30 seconds. System everywhere."
    system="system"
    chrome="system"
>
    <main class="wrap">
        <section class="hero">
            <span class="sys-label-micro">WARDROBE / SYSTEM / INSTALL</span>
            <h1 class="hero__title">INSTALL SYSTEM<br />IN 30 SECONDS_</h1>
            <p class="hero__sub">
                Pick your AI. Hit copy. Paste it into a fresh chat in your project.
                Watch the theme arrive.
            </p>
        </section>

        <section class="section">
            <div class="targets-row" role="tablist">
                <button
                    type="button"
                    role="tab"
                    class="target target--active"
                    data-target="claude-code"
                    aria-selected="true"
                >
                    CLAUDE CODE / CURSOR
                </button>
                <button
                    type="button"
                    role="tab"
                    class="target"
                    data-target="v0"
                    aria-selected="false"
                >
                    V0
                </button>
                <button
                    type="button"
                    role="tab"
                    class="target"
                    data-target="lovable"
                    aria-selected="false"
                >
                    LOVABLE
                </button>
            </div>

            <div class="copy-bar">
                <button type="button" id="copy-full" class="sys-btn sys-btn--mint sys-btn--md">
                    COPY ENTIRE PROMPT
                </button>
                <span id="copy-status" class="copy-status"></span>
            </div>

            <div class="prompt-pane" data-pane="claude-code" data-active="true">
                <pre><code>{prompts["claude-code"]}</code></pre>
            </div>
            <div class="prompt-pane" data-pane="v0">
                <pre><code>{prompts.v0}</code></pre>
            </div>
            <div class="prompt-pane" data-pane="lovable">
                <pre><code>{prompts.lovable}</code></pre>
            </div>
        </section>

        <section class="section foot">
            <p class="foot__lede">
                Once it's installed, wrap whichever section you want themed:
            </p>
            <pre class="foot__snippet"><code>{`<div data-system="system">
    <Button>HELLO SYSTEM</Button>
    <Card>...</Card>
</div>`}</code></pre>
            <p class="foot__lede">
                Want to see what it looks like in the wild?{" "}
                <a href="/system/sequence">Sequence →</a>
            </p>
        </section>

        <section class="section signup-section">
            <div class="signup-box">
                <EmailSignup
                    variant="system"
                    size="default"
                    placement="install"
                    heading="Got it working?"
                    subheading="Drop your email — I'll send you the next theme + occasional builder notes."
                />
            </div>
        </section>
    </main>

    <InstallGate />
</Layout>

<style>
    .wrap {
        max-width: 980px;
        margin: 0 auto;
        padding: 48px 24px 96px;
    }
    .hero {
        padding: 32px 0 64px;
        border-bottom: 1px solid var(--color-divider);
    }
    .hero__title {
        font-family: var(--font-display);
        font-weight: var(--weight-light);
        font-size: clamp(48px, 8vw, 96px);
        line-height: var(--display-line-height);
        letter-spacing: var(--display-letter-spacing);
        margin: 16px 0 24px;
    }
    .hero__sub {
        font-family: var(--font-body);
        font-size: 18px;
        line-height: 1.55;
        max-width: 560px;
        margin: 0;
    }

    .section {
        padding: 56px 0;
        border-bottom: 1px solid var(--color-divider);
    }
    .section:last-of-type { border-bottom: none; }

    .targets-row {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 0;
        background: var(--color-card);
        box-shadow: var(--shadow-soft);
        border-radius: var(--radius-md);
        padding: 0;
        max-width: 100%;
        margin-bottom: 28px;
    }
    .target {
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: var(--button-letter-spacing);
        font-size: 12px;
        padding: 12px 18px;
        border: none;
        background: transparent;
        color: var(--color-fg);
        cursor: pointer;
        line-height: 1;
        border-right: 1px solid var(--color-divider);
    }
    .target:last-child { border-right: none; }
    .target--active {
        background: var(--color-fg);
        color: var(--color-card);
    }

    .copy-bar {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }
    .copy-status {
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 12px;
        color: var(--color-fg-muted);
    }

    .prompt-pane { display: none; }
    .prompt-pane[data-active="true"] { display: block; }
    .prompt-pane pre {
        background: var(--color-dark-bg);
        color: var(--color-dark-fg);
        border-radius: var(--radius-md);
        padding: 22px 24px;
        margin: 0;
        max-height: 540px;
        overflow: auto;
        font-family: var(--font-mono);
        font-size: 12.5px;
        line-height: 1.65;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .foot__lede {
        font-family: var(--font-body);
        font-size: 16px;
        margin: 0 0 16px;
    }
    .foot__lede a {
        color: var(--color-fg);
        border-bottom: 1px solid var(--color-fg);
    }
    .foot__snippet {
        background: var(--color-card);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-soft);
        padding: 18px;
        font-family: var(--font-mono);
        font-size: 13px;
        line-height: 1.6;
        margin: 0 0 24px;
        overflow-x: auto;
    }

    .signup-section { padding-top: 48px; }
    .signup-box {
        background: var(--color-card);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-soft);
        padding: 32px 28px;
        max-width: 540px;
    }
</style>

<script>
    if (typeof window !== "undefined") {
        (window as any).wardrobeTrack?.("wardrobe_install_view", { system: "system" });
    }

    const targets = document.querySelectorAll<HTMLButtonElement>(".target");
    const panes = document.querySelectorAll<HTMLElement>(".prompt-pane");
    let activeTarget = "claude-code";

    targets.forEach((t) => {
        t.addEventListener("click", () => {
            activeTarget = t.dataset.target ?? "claude-code";
            targets.forEach((tt) => {
                const isActive = tt === t;
                tt.classList.toggle("target--active", isActive);
                tt.setAttribute("aria-selected", String(isActive));
            });
            panes.forEach((p) => {
                p.dataset.active = String(p.dataset.pane === activeTarget);
            });
        });
    });

    const copyBtn = document.getElementById("copy-full") as HTMLButtonElement | null;
    const copyStatus = document.getElementById("copy-status") as HTMLElement | null;

    const GATE_KEY = "wardrobe-install-unlocked";

    async function runCopy() {
        const activePane = document.querySelector<HTMLElement>(
            `.prompt-pane[data-pane="${activeTarget}"]`,
        );
        const text = activePane?.querySelector("code")?.textContent ?? "";
        try {
            await navigator.clipboard.writeText(text);
        } catch {
            const tmp = document.createElement("textarea");
            tmp.value = text;
            document.body.appendChild(tmp);
            tmp.select();
            document.execCommand("copy");
            document.body.removeChild(tmp);
        }
        if (copyStatus) {
            copyStatus.textContent = "> COPIED ✓";
            setTimeout(() => {
                if (copyStatus) copyStatus.textContent = "";
            }, 2200);
        }
        (window as any).wardrobeTrack?.("wardrobe_copy_install_full", {
            system: "system",
            target: activeTarget,
        });
    }

    copyBtn?.addEventListener("click", () => {
        let unlocked = false;
        try { unlocked = localStorage.getItem(GATE_KEY) === "true"; } catch (_) {}
        if (unlocked) {
            runCopy();
        } else {
            window.dispatchEvent(new CustomEvent("install-gate-open"));
        }
    });

    window.addEventListener("install-gate-passed", () => runCopy());
</script>
