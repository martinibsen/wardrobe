---
import Layout from "../../../layouts/Layout.astro";

type Trend = "up" | "down";
type Day = "p" | "f"; // pass | fail

const protocols: Array<{
    id: string;
    name: string;
    days: Day[];
    rate: number;
    trend: Trend;
}> = [
    { id: "01", name: "READ_30_MINS",   days: ["p", "p", "f", "p", "p", "p", "p"], rate: 86,  trend: "up"   },
    { id: "02", name: "HYDRATION_2L",   days: ["p", "p", "p", "p", "p", "p", "p"], rate: 100, trend: "up"   },
    { id: "03", name: "CODE_REVIEW",    days: ["f", "p", "p", "p", "f", "f", "p"], rate: 57,  trend: "down" },
    { id: "04", name: "MEDITATION_10M", days: ["p", "p", "p", "f", "p", "p", "p"], rate: 86,  trend: "up"   },
    { id: "05", name: "DEEP_WORK_4H",   days: ["p", "p", "p", "p", "p", "f", "f"], rate: 71,  trend: "down" },
];

const dayLabels = ["M", "T", "W", "T", "F", "S", "S"];
---

<Layout
    title="Weekly Review — Sequence"
    description="Cycle 42 audit. Execution matrix, anomalies, recommendations."
    system="system"
    chrome="hidden"
>
    <main class="rev-wrap">
        <header class="rev-header sys-card">
            <div>
                <span class="sys-label-micro">SEQUENCE REVIEW // CYCLE 42 // ENDED MAR_28</span>
                <h1 class="rev-title">Weekly System Audit</h1>
            </div>
            <div class="rev-score">
                <span class="sys-label-micro">Performance Score</span>
                <span class="rev-score__value">88<span class="rev-score__denom">/100</span></span>
            </div>
        </header>

        <section class="rev-grid">
            <article class="sys-card matrix-card">
                <span class="sys-label-micro">Execution Matrix</span>

                <table class="rev-table">
                    <thead>
                        <tr>
                            <th class="col-name">Protocol Identifier</th>
                            {dayLabels.map((d) => (<th class="col-day">{d}</th>))}
                            <th class="col-trend">Trend</th>
                        </tr>
                    </thead>
                    <tbody>
                        {protocols.map((p) => (
                            <tr>
                                <td class="col-name">
                                    <span class="rev-protocol__id">{p.id}.</span> {p.name}
                                </td>
                                {p.days.map((d) => (
                                    <td class="col-day">
                                        <span class:list={["rev-indicator", d === "p" ? "is-pass" : "is-fail"]} />
                                    </td>
                                ))}
                                <td class="col-trend">
                                    {p.rate}%
                                    <span class:list={["rev-trend", `rev-trend--${p.trend}`]}>
                                        {p.trend === "up" ? "▲" : "▼"}
                                    </span>
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>

                <div class="rev-notes">
                    <span class="sys-label-micro">System Notes</span>
                    <p>
                        Current stability is within nominal parameters (±4%). Sequence drift detected in protocols 03 and 05 during weekend cycles. High correlation between Protocol 02 compliance and overall efficiency metrics.
                    </p>
                </div>
            </article>

            <aside class="sys-card sys-card--dark analysis">
                <span class="sys-card__code-texture">{`SYS_VER: 2.0.4\nLOC: UTC-8\nMEM: 12.4GB\nLOG_ID: 99x01`}</span>
                <span class="sys-label-micro" style="color:#666;">Protocol Analysis</span>

                <div class="analysis__line">
                    <span class="analysis__tag">OPTIMIZATION</span>
                    <span class="analysis__lead">WEEKEND DRIFT DETECTED</span>
                </div>

                <p class="analysis__body">
                    Reviewing logs for Cycle 42. Data suggests a recurring failure pattern for "CODE_REVIEW" (Protocol 03) starting T+4 days.
                </p>

                <p class="analysis__body" style="margin-top: 16px;">RECOMMENDATIONS:</p>
                <ul class="analysis__list">
                    <li>&gt; Shift Protocol 03 to early AM slot.</li>
                    <li>&gt; Reduce variable friction for Protocol 05.</li>
                    <li>&gt; Initialize recovery sequence for next 48h.</li>
                </ul>

                <p class="analysis__body" style="margin-top: 16px;">
                    Current status: <span style="color: var(--color-accent);">OPERATIONAL</span><span class="sys-cursor" />
                </p>

                <div class="analysis__cta">
                    <button type="button" class="analysis__btn">COMMIT CYCLE TO DATABASE</button>
                </div>
            </aside>
        </section>
    </main>
</Layout>

<style>
    .rev-wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 32px 24px 56px;
        display: grid;
        gap: 24px;
    }
    .rev-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 24px;
        padding: 32px;
    }
    .rev-title {
        font-family: var(--font-display);
        font-weight: var(--weight-light);
        font-size: clamp(36px, 5vw, 56px);
        line-height: 1.05;
        letter-spacing: -1.5px;
        margin: 12px 0 0;
    }
    .rev-score {
        text-align: right;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .rev-score__value {
        font-family: var(--font-display);
        font-weight: var(--weight-light);
        font-size: clamp(56px, 7vw, 80px);
        line-height: 1;
        letter-spacing: -2px;
        color: var(--color-fg);
        display: inline-flex;
        align-items: baseline;
    }
    .rev-score__denom {
        font-family: var(--font-mono);
        font-size: 18px;
        color: var(--color-fg-muted);
        margin-left: 4px;
    }

    .rev-grid {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 24px;
    }

    .matrix-card { padding: 32px; gap: 12px; display: flex; flex-direction: column; }

    .rev-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 16px;
    }
    .rev-table th {
        text-align: left;
        padding: 12px 8px;
        border-bottom: 1px solid var(--color-divider);
        font-family: var(--font-mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--color-fg-muted);
        font-weight: 400;
    }
    .rev-table td {
        padding: 14px 8px;
        border-bottom: 1px solid #FAFAFA;
        font-family: var(--font-mono);
        font-size: 13px;
    }
    .rev-table .col-day { text-align: center; width: 40px; }
    .rev-table .col-trend { text-align: right; width: 100px; }
    .rev-protocol__id { color: var(--color-fg-muted); margin-right: 4px; }
    .rev-indicator {
        width: 12px;
        height: 12px;
        display: inline-block;
        border-radius: 1px;
    }
    .rev-indicator.is-pass { background: var(--color-accent); }
    .rev-indicator.is-fail { background: #EEEEEE; }
    .rev-trend { margin-left: 8px; font-family: var(--font-mono); }
    .rev-trend--up { color: var(--color-accent); }
    .rev-trend--down { color: var(--color-fail); }

    .rev-notes {
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid var(--color-divider);
    }
    .rev-notes p {
        font-family: var(--font-mono);
        font-size: 12px;
        line-height: 1.7;
        color: var(--color-fg-muted);
        margin: 8px 0 0;
    }

    .analysis {
        padding: 32px;
        display: flex;
        flex-direction: column;
    }
    .analysis__line {
        margin-top: 16px;
        padding: 4px 0;
        border-bottom: 1px solid #333;
        margin-bottom: 12px;
    }
    .analysis__tag {
        font-family: var(--font-mono);
        font-size: 9px;
        padding: 2px 6px;
        border: 1px solid #444;
        color: #888;
        margin-right: 8px;
        letter-spacing: 1px;
    }
    .analysis__lead {
        font-family: var(--font-mono);
        font-size: 13px;
        color: #FFF;
        letter-spacing: 0.05em;
    }
    .analysis__body {
        font-family: var(--font-mono);
        font-size: 13px;
        line-height: 1.7;
        color: #AAA;
        margin: 0;
    }
    .analysis__list {
        list-style: none;
        margin: 8px 0 0;
        padding: 0;
        font-family: var(--font-mono);
        font-size: 13px;
        line-height: 1.7;
        color: #AAA;
    }
    .analysis__list li { margin-bottom: 6px; }
    .analysis__cta { margin-top: auto; padding-top: 24px; }
    .analysis__btn {
        width: 100%;
        background: #333;
        color: #FFF;
        border: none;
        padding: 14px;
        cursor: pointer;
        font-family: var(--font-mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: var(--radius-md);
        transition: background var(--duration-base) var(--easing);
    }
    .analysis__btn:hover { background: var(--color-accent); color: var(--color-fg); }

    @media (max-width: 900px) {
        .rev-grid { grid-template-columns: 1fr; }
        .rev-header { flex-direction: column; align-items: flex-start; }
        .rev-score { text-align: left; }
        .rev-table .col-day { width: 32px; }
    }
</style>

<script>
    if (typeof window !== "undefined") {
        (window as any).wardrobeTrack?.("wardrobe_demo_view", {
            system: "system",
            page: "sequence/review",
        });
    }
</script>
