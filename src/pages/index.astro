<script>
    if (typeof window !== "undefined") {
        (window as any).wardrobeTrack?.("wardrobe_view");
    }

    // Vibe filter — pill click filters cards by data-tags. "all" resets.
    // Random button picks a non-"all" pill at random and jiggles it.
    (function () {
        const pills = document.querySelectorAll<HTMLButtonElement>("[data-vibe]");
        const cards = document.querySelectorAll<HTMLElement>(
            ".theme-card",
        );
        const randomBtn = document.querySelector<HTMLButtonElement>("[data-vibe-random]");
        if (!pills.length || !cards.length) return;

        function applyFilter(vibe: string, sourcePill?: HTMLElement) {
            pills.forEach((p) => {
                const active = p.dataset.vibe === vibe;
                p.classList.toggle("is-active", active);
                p.setAttribute("aria-selected", String(active));
            });
            cards.forEach((card) => {
                if (vibe === "all") {
                    card.removeAttribute("data-dimmed");
                    return;
                }
                const tags = (card.getAttribute("data-tags") || "")
                    .toLowerCase()
                    .split(/\s+/)
                    .filter(Boolean);
                const matches = tags.includes(vibe);
                if (matches) card.removeAttribute("data-dimmed");
                else card.setAttribute("data-dimmed", "true");
            });
            if (sourcePill) {
                sourcePill.classList.remove("is-jiggling");
                // restart animation
                void sourcePill.offsetWidth;
                sourcePill.classList.add("is-jiggling");
                setTimeout(() => sourcePill.classList.remove("is-jiggling"), 280);
            }
            (window as any).wardrobeTrack?.("wardrobe_vibe_filter", { vibe });
        }

        pills.forEach((p) => {
            p.addEventListener("click", () => {
                const vibe = p.dataset.vibe ?? "all";
                applyFilter(vibe, p);
            });
        });

        if (randomBtn) {
            const vibes = Array.from(pills)
                .map((p) => p.dataset.vibe ?? "")
                .filter((v) => v && v !== "all");
            randomBtn.addEventListener("click", () => {
                if (!vibes.length) return;
                const pick = vibes[Math.floor(Math.random() * vibes.length)];
                const matchingPill = document.querySelector<HTMLElement>(
                    `[data-vibe="${pick}"]`,
                );
                applyFilter(pick, matchingPill ?? undefined);
                (window as any).wardrobeTrack?.("wardrobe_vibe_random", { picked: pick });
            });
        }
    })();
</script>
