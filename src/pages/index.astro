---
import Layout from "../layouts/Layout.astro";
import EmailSignup from "../components/shared/EmailSignup.astro";
---

<Layout
    title="Wardrobe — themes for vibe-coded apps"
    description="Visual themes for what you're vibe-coding. Pick one. Copy the prompt. Paste in your AI tool. Ship a UI that doesn't look like everything else."
    chrome="neutral"
>
    <main class="wrap">
        <section class="hero">
            <h1 class="h1">Visual themes for what you're vibe-coding.</h1>
            <p class="lede">
                Pick one. Copy the prompt. Paste in your AI tool.
                Ship a UI that doesn't look like everything else.
            </p>

            <div class="hero__cta">
                <a class="hero__primary" href="#themes">Browse themes →</a>
            </div>

            <p class="sub">
                Made by <a href="https://martinibsen.dk" target="_blank" rel="noopener">Martin Ibsen</a>
                — drop-in ready for Claude Code, Cursor, v0, Lovable, your shadcn project, whatever.
                Free to use.
            </p>
        </section>

        <section class="block" id="themes">
            <div class="block__head">
                <h2 class="h2">Themes</h2>
            </div>

            <div class="vibe-bar" data-vibe-bar>
                <span class="vibe-bar__label">filter by vibe →</span>
                <div class="vibe-pills" role="tablist" aria-label="Filter themes by vibe">
                    <button type="button" role="tab" class="vibe-pill is-active" data-vibe="all" aria-selected="true">all</button>
                    <button type="button" role="tab" class="vibe-pill" data-vibe="loud" aria-selected="false">loud</button>
                    <button type="button" role="tab" class="vibe-pill" data-vibe="calm" aria-selected="false">calm</button>
                    <button type="button" role="tab" class="vibe-pill" data-vibe="brutal" aria-selected="false">brutal</button>
                    <button type="button" role="tab" class="vibe-pill" data-vibe="tactile" aria-selected="false">tactile</button>
                    <button type="button" role="tab" class="vibe-pill" data-vibe="editorial" aria-selected="false">editorial</button>
                    <button type="button" role="tab" class="vibe-pill" data-vibe="glass" aria-selected="false">glass</button>
                    <button type="button" role="tab" class="vibe-pill" data-vibe="paper" aria-selected="false">paper</button>
                    <button type="button" role="tab" class="vibe-pill" data-vibe="colorful" aria-selected="false">colorful!</button>
                </div>
                <button type="button" class="vibe-random" data-vibe-random aria-label="Pick a random vibe">🎲</button>
            </div>

            <div class="grid">
                <a class="theme-card theme-card--hyper" href="/hyper" data-tags="loud brutal caps colorful y2k anti-corporate">
                    <div class="theme-card__preview theme-card__preview--hyper">
                        <div class="hp-card" aria-hidden="true">
                            <span class="hp-badge">03</span>
                            <span class="hp-eyebrow">SAT · 09:00</span>
                            <span class="hp-display">10K.</span>
                            <span class="hp-pill">JOIN CLUB →</span>
                        </div>
                    </div>
                    <div class="theme-card__meta">
                        <span class="theme-card__name">Hyper</span>
                        <span class="theme-card__vibe">
                            Loud, brutalist, anti-corporate. CAPS forever.
                        </span>
                        <span class="theme-card__cta">Try Hyper →</span>
                    </div>
                </a>

                <a class="theme-card theme-card--system" href="/system" data-tags="calm terminal mono monochrome quantified">
                    <div class="theme-card__preview theme-card__preview--system" aria-hidden="true">
                        <div class="sys-row sys-row--top">
                            <span class="sys-label">PROTOCOL · RUN_07</span>
                            <span class="sys-status">
                                <span class="sys-dot"></span>
                                <span class="sys-mono">LIVE</span>
                            </span>
                        </div>
                        <span class="sys-display">47:23</span>
                        <div class="sys-bar">
                            <div class="sys-bar__fill"></div>
                        </div>
                        <div class="sys-row sys-row--bot">
                            <span class="sys-mono">96% EFFICIENCY_</span>
                            <span class="sys-mono sys-mono--faint">+0.3</span>
                        </div>
                    </div>
                    <div class="theme-card__meta">
                        <span class="theme-card__name">System</span>
                        <span class="theme-card__vibe">
                            Terminal precision. Quantified-self for the post-Headspace generation.
                        </span>
                        <span class="theme-card__cta">Try System →</span>
                    </div>
                </a>

                <a class="theme-card theme-card--brick" href="/brick" data-tags="tactile hardware skeuomorphic raised colorful">
                    <div class="theme-card__preview theme-card__preview--brick" aria-hidden="true">
                        <span class="brk-label">BR-68 / MK-1 · CONTROL</span>
                        <div class="brk-panel">
                            <div class="brk-readout">
                                <span class="brk-readout-mini">VOL</span>
                                <span class="brk-readout-num">07</span>
                            </div>
                            <div class="brk-buttons">
                                <span class="brk-btn brk-btn--red"></span>
                                <span class="brk-btn brk-btn--blue"></span>
                                <span class="brk-btn brk-btn--green"></span>
                            </div>
                        </div>
                    </div>
                    <div class="theme-card__meta">
                        <span class="theme-card__name">Brick</span>
                        <span class="theme-card__vibe">
                            Hardware aesthetics for software builds. Embossed panels. Tactile feel.
                        </span>
                        <span class="theme-card__cta">[ Try Brick → ]</span>
                    </div>
                </a>

                <a class="theme-card theme-card--bluey" href="/bluey" data-tags="calm editorial glass composed colorful">
                    <div class="theme-card__preview theme-card__preview--bluey" aria-hidden="true">
                        <div class="bly-prev-blob"></div>
                        <div class="bly-prev-tag">
                            <span class="bly-prev-pulse"></span>
                            <span>VALIDATION · LIVE</span>
                        </div>
                        <div class="bly-prev-card">
                            <span class="bly-prev-label">Confidence</span>
                            <span class="bly-prev-score">72</span>
                        </div>
                        <span class="bly-prev-vertical">SUPERYES — REV 01</span>
                    </div>
                    <div class="theme-card__meta">
                        <span class="theme-card__name">Bluey</span>
                        <span class="theme-card__vibe">
                            Editorial calm. Composed authority.
                        </span>
                        <span class="theme-card__cta">See Bluey →</span>
                    </div>
                </a>

                <a class="theme-card theme-card--pascal" href="/pascal" data-tags="brutal paper swiss editorial mono caps archive">
                    <div class="theme-card__preview theme-card__preview--pascal" aria-hidden="true">
                        <div class="psc-prev-grid">
                            <div class="psc-prev-cell psc-prev-head">
                                <span class="psc-prev-label">INDEX.V5</span>
                                <span class="psc-prev-title">PASCAL.</span>
                            </div>
                            <div class="psc-prev-cell psc-prev-mint">
                                <span class="psc-prev-label">STATUS</span>
                                <span class="psc-prev-mono">LIVE_NODE</span>
                            </div>
                            <div class="psc-prev-cell psc-prev-pink">
                                <span class="psc-prev-label">REV</span>
                                <span class="psc-prev-mono">v4.02.b</span>
                            </div>
                        </div>
                        <div class="psc-prev-marquee">
                            <span class="psc-prev-marquee-track">
                                SYSTEM STATUS: OPERATIONAL // DATA STREAMS: ACTIVE // NODE_ID: PASCAL_ROOT // SYSTEM STATUS: OPERATIONAL //
                            </span>
                        </div>
                    </div>
                    <div class="theme-card__meta">
                        <span class="theme-card__name">Pascal</span>
                        <span class="theme-card__vibe">
                            Brutalist bureaucracy. Paper logic.
                        </span>
                        <span class="theme-card__cta">See Pascal →</span>
                    </div>
                </a>

                <a class="theme-card theme-card--nodesign" href="/nodesign" data-tags="minimal calm editorial composed mono">
                    <div class="theme-card__preview theme-card__preview--nodesign" aria-hidden="true">
                        <span class="nds-prev-tl">Work</span>
                        <span class="nds-prev-tc">Studio Architecture</span>
                        <span class="nds-prev-tr">About</span>
                        <span class="nds-prev-focal">N O D E S I G N</span>
                    </div>
                    <div class="theme-card__meta">
                        <span class="theme-card__name">Nodesign</span>
                        <span class="theme-card__vibe">
                            The absence is the design.
                        </span>
                        <span class="theme-card__cta">See Nodesign →</span>
                    </div>
                </a>

                <div class="theme-card theme-card--soon">
                    <div class="theme-card__preview theme-card__preview--soon">
                        <span class="theme-card__soon-mark">SOON</span>
                    </div>
                    <div class="theme-card__meta theme-card__meta--soon">
                        <span class="theme-card__soon-label">Theme 07 — In the works</span>
                        <span class="theme-card__soon-blurb">Sign up below to hear when it drops.</span>
                    </div>
                </div>
            </div>

            <div class="themes-signup">
                <EmailSignup
                    variant="neutral"
                    size="default"
                    placement="hero"
                    heading="Get notified on the next drop."
                />
            </div>
        </section>

        <section class="block">
            <div class="block__head">
                <h2 class="h2">How it works</h2>
            </div>
            <ol class="steps">
                <li>
                    <span class="step__num">01</span>
                    <span class="step__body">Pick a theme.</span>
                </li>
                <li>
                    <span class="step__num">02</span>
                    <span class="step__body">Copy the install-prompt.</span>
                </li>
                <li>
                    <span class="step__num">03</span>
                    <span class="step__body">Paste in your AI session.</span>
                </li>
            </ol>
        </section>
    </main>
</Layout>

<style>
    .wrap {
        max-width: 920px;
        margin: 0 auto;
        padding: 64px 24px 96px;
    }
    .hero {
        margin-bottom: 96px;
        max-width: 720px;
    }
    .eyebrow {
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #525252;
        margin: 0 0 16px;
    }
    .h1 {
        font-size: clamp(40px, 6vw, 64px);
        line-height: 1.05;
        letter-spacing: -0.02em;
        font-weight: 600;
        color: #0a0a0a;
        margin: 0 0 24px;
    }
    .lede {
        font-size: 22px;
        line-height: 1.45;
        color: #0a0a0a;
        margin: 0 0 32px;
    }
    .hero__cta {
        margin: 0 0 32px;
    }
    .hero__primary {
        display: inline-block;
        padding: 14px 22px;
        background: #0a0a0a;
        color: #ffffff;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 500;
        text-decoration: none;
        transition: background 120ms ease;
    }
    .hero__primary:hover { background: #2a2a2a; }
    .sub {
        font-size: 15px;
        line-height: 1.55;
        color: #525252;
        margin: 0;
    }
    .sub a { color: #0a0a0a; text-decoration: underline; }

    .block { margin-bottom: 96px; }
    .block:last-child { margin-bottom: 0; }
    .block__head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        border-bottom: 1px solid #e5e5e5;
        padding-bottom: 16px;
        margin-bottom: 32px;
    }
    .h2 {
        font-size: 24px;
        font-weight: 600;
        color: #0a0a0a;
        margin: 0;
        letter-spacing: -0.01em;
    }
    .muted { color: #525252; font-size: 13px; }

    /* ===== Vibe filter bar ===== */
    .vibe-bar {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin: 0 0 24px;
    }
    .vibe-bar__label {
        font-family: inherit;
        font-size: 14px;
        color: #737373;
        flex-shrink: 0;
    }
    .vibe-pills {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        flex: 1;
        min-width: 0;
    }
    .vibe-pill {
        background: #fafafa;
        border: 1px solid #e5e5e5;
        color: #525252;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-family: inherit;
        cursor: pointer;
        line-height: 1.3;
        transition:
            background 120ms ease,
            color 120ms ease,
            border-color 120ms ease,
            transform 120ms ease;
    }
    .vibe-pill:hover {
        background: #f0f0f0;
        color: #0a0a0a;
        border-color: #d4d4d4;
    }
    .vibe-pill.is-active {
        background: #0a0a0a;
        color: #ffffff;
        border-color: #0a0a0a;
    }
    .vibe-pill:focus-visible {
        outline: 2px solid #0a0a0a;
        outline-offset: 2px;
    }
    @keyframes vibe-pill-jiggle {
        0%, 100% { transform: rotate(0); }
        25% { transform: rotate(-3deg); }
        75% { transform: rotate(3deg); }
    }
    .vibe-pill.is-jiggling {
        animation: vibe-pill-jiggle 240ms ease;
    }
    .vibe-random {
        background: #fafafa;
        border: 1px solid #e5e5e5;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        cursor: pointer;
        font-size: 15px;
        line-height: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background 120ms ease, transform 200ms ease;
    }
    .vibe-random:hover {
        background: #f0f0f0;
        transform: rotate(20deg);
    }
    .vibe-random:focus-visible {
        outline: 2px solid #0a0a0a;
        outline-offset: 2px;
    }
    .vibe-random:active { transform: rotate(360deg); }

    /* Hide cards that don't match the active filter. */
    .theme-card[data-dimmed="true"] {
        display: none;
    }
    .theme-card {
        transition: border-color 200ms ease;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }
    @media (max-width: 960px) {
        .grid { grid-template-columns: repeat(2, 1fr); }
    }
    .theme-card {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        border: 1px solid #e5e5e5;
        border-radius: 8px;
        overflow: hidden;
        transition: border-color 200ms ease;
    }
    .theme-card:not(.theme-card--ghost):not(.theme-card--soon):hover {
        border-color: #0a0a0a;
    }
    .theme-card__preview {
        padding: 28px 24px;
        display: flex;
        min-height: 220px;
    }
    .theme-card__preview--ghost {
        background: #fafafa;
        color: #d4d4d4;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
    }
    .theme-card__display {
        font-family: "Anton", "Impact", "Arial Narrow", sans-serif;
        font-size: 64px;
        line-height: 0.85;
        letter-spacing: -0.02em;
        text-transform: uppercase;
    }

    /* ===== HYPER vignette: a Marathon-Club event card =====
       Signature Hyper patterns on display: brown 1px border,
       hard offset shadow, numeric badge poking the corner,
       Anton CAPS with period, acid-yellow + pill button. */
    .theme-card__preview--hyper {
        background: #efff71;
        color: #3a1e1e;
        align-items: center;
        justify-content: center;
        padding: 32px 28px;
    }
    .hp-card {
        position: relative;
        background: #ffffff;
        border: 1px solid #3a1e1e;
        box-shadow: 4px 4px 0 #3a1e1e;
        padding: 18px 22px 20px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 220px;
    }
    .hp-badge {
        position: absolute;
        top: -14px;
        right: 18px;
        width: 28px;
        height: 28px;
        background: #ffffff;
        border: 1px solid #3a1e1e;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Anton", "Impact", sans-serif;
        font-size: 14px;
        line-height: 1;
        color: #3a1e1e;
    }
    .hp-eyebrow {
        font-family: Georgia, serif;
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #3a1e1e;
        opacity: 0.7;
    }
    .hp-display {
        font-family: "Anton", "Impact", "Arial Narrow", sans-serif;
        font-size: 56px;
        line-height: 0.85;
        letter-spacing: -0.02em;
        text-transform: uppercase;
        color: #3a1e1e;
        margin-bottom: 4px;
    }
    .hp-pill {
        align-self: flex-start;
        margin-top: 6px;
        background: #3a1e1e;
        color: #efff71;
        padding: 7px 14px;
        border-radius: 32px;
        font-family: "Anton", "Impact", sans-serif;
        font-size: 12px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    /* ===== SYSTEM vignette: a protocol stat readout =====
       Big light display number, monospace labels, mint dot,
       progress bar, faint baseline grid pattern. */
    .theme-card__preview--system {
        background: #f4f4f4;
        color: #0d0d0d;
        flex-direction: column;
        justify-content: space-between;
        gap: 0;
        padding: 22px 24px;
        position: relative;
    }
    .theme-card__preview--system::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: linear-gradient(to right, rgba(0, 0, 0, 0.035) 1px, transparent 1px);
        background-size: 28px 100%;
        pointer-events: none;
    }
    .theme-card__preview--system > * {
        position: relative;
    }
    .sys-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .sys-label {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 10px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #888;
    }
    .sys-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .sys-dot {
        width: 8px;
        height: 8px;
        background: #6cefa0;
        border-radius: 1px;
        display: inline-block;
    }
    .sys-mono {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #0d0d0d;
    }
    .sys-mono--faint { color: #888; }
    .sys-display {
        font-family: "Space Grotesk", -apple-system, sans-serif;
        font-size: 56px;
        line-height: 1;
        letter-spacing: -2px;
        font-weight: 300;
        color: #0d0d0d;
        align-self: flex-start;
    }
    .sys-bar {
        height: 3px;
        background: #e0e0e0;
        position: relative;
    }
    .sys-bar__fill {
        position: absolute;
        inset: 0 4% 0 0;
        background: #0d0d0d;
    }

    /* ===== BRICK vignette: hardware control panel =====
       Embossed casing background, recessed sub-panel, raised
       buttons with colored LEDs, LCD-style readout. */
    .theme-card__preview--brick {
        background: #e3e4df;
        color: #1a1a1a;
        flex-direction: column;
        gap: 14px;
        padding: 22px 22px 24px;
        box-shadow:
            inset 1px 1px 2px rgba(255, 255, 255, 0.7),
            inset -1px -1px 3px rgba(0, 0, 0, 0.08);
    }
    .brk-label {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-weight: 700;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #6a6b66;
    }
    .brk-panel {
        flex: 1;
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 12px;
        padding: 12px;
        background: #dadbd4;
        border-radius: 4px;
        box-shadow:
            inset 1px 1px 2px rgba(0, 0, 0, 0.14),
            inset -1px -1px 1px rgba(255, 255, 255, 0.5);
    }
    .brk-readout {
        background: #1a1a1a;
        color: #6cefa0;
        border-radius: 3px;
        padding: 10px 14px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: inset 1px 1px 3px rgba(0, 0, 0, 0.6);
    }
    .brk-readout-mini {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 9px;
        letter-spacing: 0.18em;
        opacity: 0.55;
        text-transform: uppercase;
    }
    .brk-readout-num {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 36px;
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.02em;
        align-self: flex-end;
    }
    .brk-buttons {
        display: grid;
        grid-template-rows: 1fr 1fr 1fr;
        gap: 6px;
    }
    .brk-btn {
        position: relative;
        background: linear-gradient(180deg, #efefea 0%, #e0e0db 100%);
        border-radius: 5px;
        box-shadow:
            inset 1px 1px 1px rgba(255, 255, 255, 0.85),
            inset -1px -1px 1px rgba(0, 0, 0, 0.08),
            0 2px 3px rgba(0, 0, 0, 0.18);
    }
    .brk-btn::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        transform: translate(-50%, -50%);
        box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.25);
    }
    .brk-btn--red::after { background: #d03027; }
    .brk-btn--blue::after { background: #0055a4; }
    .brk-btn--green::after { background: #00853e; }

    .theme-card__meta {
        padding: 22px 24px 24px;
        background: #ffffff;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .theme-card__name {
        font-size: 17px;
        font-weight: 600;
        color: #0a0a0a;
    }

    /* Per-theme: name in the theme's own display voice */
    .theme-card--hyper .theme-card__name {
        font-family: "Anton", "Impact", "Arial Narrow", sans-serif;
        font-size: 40px;
        font-weight: 400;
        line-height: 0.9;
        letter-spacing: -0.01em;
        text-transform: uppercase;
        color: #3a1e1e;
    }
    .theme-card--hyper .theme-card__name::after { content: "."; }
    .theme-card--system .theme-card__name {
        font-family: "Space Grotesk", -apple-system, sans-serif;
        font-size: 36px;
        font-weight: 300;
        line-height: 1;
        letter-spacing: -1.5px;
        color: #0d0d0d;
    }
    .theme-card--brick .theme-card__name {
        font-family: "Inter", -apple-system, sans-serif;
        font-size: 34px;
        font-weight: 600;
