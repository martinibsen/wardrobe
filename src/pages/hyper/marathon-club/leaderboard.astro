---
import Layout from "../../../layouts/Layout.astro";

const baseRunners = [
    { name: "Astrid Nørgaard", distance: 182, pace: "4:42", streak: 14 },
    { name: "Lasse Møller", distance: 164, pace: "4:51", streak: 12 },
    { name: "Mette Pedersen", distance: 152, pace: "4:55", streak: 9 },
    { name: "Frederik Holm", distance: 138, pace: "5:01", streak: 18 },
    { name: "Sigrid Vestergaard", distance: 131, pace: "5:04", streak: 7 },
    { name: "Jonas Lindberg", distance: 124, pace: "5:08", streak: 11 },
    { name: "Liva Jensen", distance: 118, pace: "5:12", streak: 8 },
    { name: "Mads Sørensen", distance: 112, pace: "5:14", streak: 13 },
    { name: "Karoline Bach", distance: 106, pace: "5:17", streak: 6 },
    { name: "Thor Andresen", distance: 102, pace: "5:20", streak: 9 },
    { name: "Emilie Holm", distance: 98, pace: "5:23", streak: 4 },
    { name: "Oliver Friis", distance: 92, pace: "5:25", streak: 5 },
    { name: "Cecilie Brandt", distance: 88, pace: "5:28", streak: 7 },
    { name: "Magnus Iversen", distance: 84, pace: "5:30", streak: 3 },
    { name: "Naja Kristensen", distance: 80, pace: "5:33", streak: 6 },
    { name: "Albert Lund", distance: 76, pace: "5:36", streak: 5 },
    { name: "Ida Madsen", distance: 72, pace: "5:39", streak: 4 },
    { name: "Otto Vinther", distance: 68, pace: "5:41", streak: 3 },
    { name: "Selma Krogh", distance: 64, pace: "5:45", streak: 5 },
    { name: "Anker Bay", distance: 60, pace: "5:48", streak: 4 },
];
---

<Layout
    title="Leaderboard — Marathon Club"
    description="Top 20 runners this month. Distance, pace, streak."
    system="hyper"
    chrome="hidden"
>
    <main class="mc-wrap">
        <header class="mc-header">
            <div class="mc-brand">
                <h1 class="mc-brand__title">LEADER /<br />BOARD.</h1>
                <p class="mc-brand__sub">April 2026 · 20 runners ranked</p>
            </div>
        </header>

        <section class="hero-card-wrap">
            <div class="hyp-card hyp-card--blue mc-hero-card">
                <span class="hyp-badge-circle">01</span>
                <p class="mc-hero-card__label">MONTH SO FAR.</p>
                <h2 class="mc-hero-card__display">1,420 km<br />collective.</h2>
                <p class="mc-hero-card__detail">Across 20 ranked runners. Pace median 5:16/km.</p>
            </div>
        </section>

        <div class="tabs-wrap">
            <div class="hyp-tabs" role="tablist" id="lb-tabs">
                <button type="button" class="hyp-tabs__btn hyp-tabs__btn--active" data-sort="distance">DISTANCE</button>
                <button type="button" class="hyp-tabs__btn" data-sort="pace">PACE</button>
                <button type="button" class="hyp-tabs__btn" data-sort="streak">STREAK</button>
            </div>
            <span class="tabs-hint">— sort the board</span>
        </div>

        <ol class="board" id="board">
            {baseRunners.map((r, i) => (
                <li
                    class="board__row"
                    data-distance={r.distance}
                    data-pace={r.pace}
                    data-streak={r.streak}
                >
                    <span class="board__rank">{String(i + 1).padStart(2, "0")}</span>
                    <span class="board__name">{r.name}</span>
                    <span class="board__stat board__stat--distance">{r.distance} KM</span>
                    <span class="board__stat board__stat--pace">{r.pace}/KM</span>
                    <span class="board__stat board__stat--streak">{r.streak}D</span>
                </li>
            ))}
        </ol>

        <footer class="mc-footer">
            <p class="mc-footer__line">MARATHON CLUB. — Every street is a track. © 2026</p>
            <p class="mc-footer__built"><a href="/hyper">Built with Wardrobe / Hyper →</a></p>
        </footer>
    </main>

    <nav class="hyp-bottom-nav" aria-label="Marathon Club">
        <a class="hyp-bottom-nav__item" href="/hyper/marathon-club">HOME</a>
        <a class="hyp-bottom-nav__item" href="/hyper/marathon-club/events">EVENTS</a>
        <a class="hyp-bottom-nav__item" href="/hyper/marathon-club/membership">JOIN</a>
        <a class="hyp-bottom-nav__item hyp-bottom-nav__item--active" href="/hyper/marathon-club/leaderboard">RANK</a>
    </nav>
</Layout>

<style>
    .mc-wrap { max-width: 760px; margin: 0 auto; padding: 24px 20px 140px; }
    .mc-header {
        display: flex; justify-content: space-between; align-items: flex-start;
        margin-bottom: 28px; gap: 16px;
    }
    .mc-brand__title {
        font-family: var(--font-display); text-transform: uppercase;
        font-size: clamp(48px, 12vw, 80px); line-height: 0.85;
        letter-spacing: -0.02em; margin: 0;
    }
    .mc-brand__sub { font-family: var(--font-body); font-size: 13px; opacity: 0.75; margin: 8px 0 0; }
    .mc-back {
        font-family: var(--font-display); text-transform: uppercase; font-size: 12px;
        letter-spacing: 0.5px; color: var(--color-fg); text-decoration: none;
        background: var(--color-surface); border: var(--border); border-radius: var(--radius-pill);
        padding: 8px 14px;
    }

    .hero-card-wrap { margin-bottom: 24px; }
    .mc-hero-card { padding: 24px 22px; }
    .mc-hero-card__label {
        font-family: var(--font-display); text-transform: uppercase;
        font-size: 13px; letter-spacing: 0.05em; margin: 0;
    }
    .mc-hero-card__display {
        font-family: var(--font-display); text-transform: uppercase;
        font-size: clamp(44px, 10vw, 72px);
        line-height: 0.9; letter-spacing: -0.02em; margin: 8px 0 12px;
    }
    .mc-hero-card__detail {
        font-family: var(--font-body); font-size: 14px; line-height: 1.5; margin: 0;
    }

    .tabs-wrap {
        display: flex; align-items: center; gap: 14px;
        margin-bottom: 18px; flex-wrap: wrap;
    }
    .tabs-hint {
        font-family: var(--font-body); font-size: 13px; opacity: 0.7;
    }

    .board {
        list-style: none; padding: 0; margin: 0;
        background: var(--color-surface);
        border: var(--border);
        border-radius: var(--radius-md);
        overflow: hidden;
    }
    .board__row {
        display: grid;
        grid-template-columns: 48px 1fr auto auto auto;
        align-items: center;
        gap: 16px;
        padding: 14px 18px;
        border-bottom: 1px solid rgba(58, 30, 30, 0.18);
        transition: background var(--duration-fast) var(--easing);
    }
    .board__row:last-child { border-bottom: none; }
    .board__row:hover { background: rgba(58, 30, 30, 0.04); }
    .board__rank {
        font-family: var(--font-display); text-transform: uppercase;
        font-size: 24px; letter-spacing: -0.01em;
    }
    .board__name {
        font-family: var(--font-body); font-size: 16px;
    }
    .board__stat {
        font-family: var(--font-display); text-transform: uppercase;
        font-size: 16px; letter-spacing: -0.01em;
        opacity: 0.6;
    }
    .board[data-sort="distance"] .board__stat--distance,
    .board[data-sort="pace"] .board__stat--pace,
    .board[data-sort="streak"] .board__stat--streak {
        opacity: 1;
        font-size: 22px;
    }

    @media (max-width: 600px) {
        .board__row { grid-template-columns: 36px 1fr auto; }
        .board__stat { display: none; }
        .board[data-sort="distance"] .board__stat--distance,
        .board[data-sort="pace"] .board__stat--pace,
        .board[data-sort="streak"] .board__stat--streak { display: inline; }
    }

    .mc-footer {
        text-align: center; font-family: var(--font-body); font-size: 12px;
        margin-top: 28px; padding-top: 18px; border-top: var(--border);
    }
    .mc-footer__line { margin: 0; opacity: 0.85; }
    .mc-footer__built { margin: 8px 0 0; }
    .mc-footer__built a {
        color: var(--color-fg); text-decoration: none;
        font-family: var(--font-display); text-transform: uppercase;
        letter-spacing: 0.05em; font-size: 11px;
    }
</style>

<script>
    if (typeof window !== "undefined") {
        (window as any).wardrobeTrack?.("wardrobe_demo_view", {
            system: "hyper",
            page: "marathon-club/leaderboard",
        });
    }

    const board = document.getElementById("board") as HTMLElement | null;
    const tabs = document.querySelectorAll<HTMLButtonElement>("#lb-tabs .hyp-tabs__btn");

    function paceToSeconds(p: string) {
        const [m, s] = p.split(":").map(Number);
        return m * 60 + s;
    }

    function sortBoard(by: string) {
        if (!board) return;
        const rows = Array.from(board.children) as HTMLElement[];
        rows.sort((a, b) => {
            if (by === "pace") {
                return (
                    paceToSeconds(a.dataset.pace ?? "0:00") -
                    paceToSeconds(b.dataset.pace ?? "0:00")
                );
            }
            const av = Number(a.dataset[by] ?? 0);
            const bv = Number(b.dataset[by] ?? 0);
            return bv - av;
        });
        rows.forEach((row, i) => {
            const rank = row.querySelector<HTMLElement>(".board__rank");
            if (rank) rank.textContent = String(i + 1).padStart(2, "0");
            board.appendChild(row);
        });
        board.dataset.sort = by;
    }

    tabs.forEach((t) => {
        t.addEventListener("click", () => {
            tabs.forEach((tt) => tt.classList.toggle("hyp-tabs__btn--active", tt === t));
            sortBoard(t.dataset.sort ?? "distance");
        });
    });

    sortBoard("distance");
</script>
