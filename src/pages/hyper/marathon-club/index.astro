---
import Layout from "../../../layouts/Layout.astro";
---

<Layout
    title="Marathon Club — every street is a track"
    description="Marathon Club is a fictional running club. The whole site runs on Wardrobe / Hyper."
    system="hyper"
    chrome="hidden"
>
    <main class="mc-wrap">
        <header class="mc-header">
            <div class="mc-brand">
                <h1 class="mc-brand__title">MARATHON /<br />CLUB.</h1>
                <p class="mc-brand__sub">Tuesday, Apr 28 · Aarhus</p>
            </div>
        </header>

        <section class="mc-hero">
            <div class="hyp-card hyp-card--blue mc-hero-card">
                <span class="hyp-badge-circle">01</span>
                <p class="mc-hero-card__label">NEXT RUN.</p>
                <h2 class="mc-hero-card__display">Sunday<br />Apr 28.</h2>
                <p class="mc-hero-card__detail">Aarhus harbour 10K · 8.30am · Free for members</p>
                <div class="mc-hero-card__cta">
                    <a class="hyp-btn hyp-btn--primary hyp-btn--md" href="/hyper/marathon-club/events">SIGN ME UP →</a>
                </div>
            </div>
        </section>

        <section class="mc-stats">
            <div class="hyp-card hyp-card--pink mc-stat">
                <span class="hyp-badge-circle">02</span>
                <span class="mc-stat__label">MEMBERS</span>
                <span class="mc-stat__value">234</span>
            </div>
            <div class="hyp-card hyp-card--green mc-stat">
                <span class="hyp-badge-circle">03</span>
                <span class="mc-stat__label">EVENTS YEAR</span>
                <span class="mc-stat__value">47</span>
            </div>
            <div class="hyp-card hyp-card--blue mc-stat">
                <span class="hyp-badge-circle">04</span>
                <span class="mc-stat__label">TOTAL KM</span>
                <span class="mc-stat__value">1,920</span>
            </div>
        </section>

        <h3 class="hyp-section-title">UPCOMING.</h3>
        <div class="mc-events">
            <article class="hyp-card mc-event">
                <div class="mc-event__date"><strong>SUN</strong><span>28</span></div>
                <div class="mc-event__body">
                    <h4 class="mc-event__title">Aarhus Harbour 10K</h4>
                    <p class="mc-event__meta">8.30am · Easy pace · 10km</p>
                </div>
                <span class="hyp-badge hyp-badge--filled">FREE</span>
            </article>

            <article class="hyp-card hyp-card--pink mc-event">
                <div class="mc-event__date"><strong>WED</strong><span>01</span></div>
                <div class="mc-event__body">
                    <h4 class="mc-event__title">Hill repeats — Risskov</h4>
                    <p class="mc-event__meta">6.30pm · Hard · 6km vertical</p>
                </div>
                <span class="hyp-badge">MEMBERS</span>
            </article>

            <article class="hyp-card hyp-card--green mc-event">
                <div class="mc-event__date"><strong>SAT</strong><span>04</span></div>
                <div class="mc-event__body">
                    <h4 class="mc-event__title">Long run — Marselis Forest</h4>
                    <p class="mc-event__meta">9.00am · Steady · 22km</p>
                </div>
                <span class="hyp-badge hyp-badge--filled">PACERS</span>
            </article>
        </div>

        <h3 class="hyp-section-title">TOP RUNNERS THIS MONTH.</h3>
        <div class="mc-runners">
            <article class="hyp-card mc-runner">
                <span class="hyp-badge-circle">01</span>
                <div class="mc-runner__name">Astrid Nørgaard</div>
                <div class="mc-runner__stat">182 KM</div>
            </article>
            <article class="hyp-card hyp-card--pink mc-runner">
                <span class="hyp-badge-circle">02</span>
                <div class="mc-runner__name">Lasse Møller</div>
                <div class="mc-runner__stat">164 KM</div>
            </article>
            <article class="hyp-card hyp-card--blue mc-runner">
                <span class="hyp-badge-circle">03</span>
                <div class="mc-runner__name">Mette Pedersen</div>
                <div class="mc-runner__stat">152 KM</div>
            </article>
            <article class="hyp-card hyp-card--green mc-runner">
                <span class="hyp-badge-circle">04</span>
                <div class="mc-runner__name">Frederik Holm</div>
                <div class="mc-runner__stat">138 KM</div>
            </article>
            <article class="hyp-card mc-runner">
                <span class="hyp-badge-circle">05</span>
                <div class="mc-runner__name">Sigrid Vestergaard</div>
                <div class="mc-runner__stat">131 KM</div>
            </article>
        </div>

        <div class="mc-cta">
            <a class="hyp-btn hyp-btn--primary hyp-btn--lg" href="/hyper/marathon-club/membership">JOIN THE CLUB →</a>
        </div>

        <footer class="mc-footer">
            <p class="mc-footer__line">
                MARATHON CLUB. — Every street is a track. © 2026
            </p>
            <p class="mc-footer__built">
                <a href="/hyper">Built with Wardrobe / Hyper →</a>
            </p>
        </footer>
    </main>

    <nav class="hyp-bottom-nav" aria-label="Marathon Club">
        <a class="hyp-bottom-nav__item hyp-bottom-nav__item--active" href="/hyper/marathon-club">HOME</a>
        <a class="hyp-bottom-nav__item" href="/hyper/marathon-club/events">EVENTS</a>
        <a class="hyp-bottom-nav__item" href="/hyper/marathon-club/membership">JOIN</a>
        <a class="hyp-bottom-nav__item" href="/hyper/marathon-club/leaderboard">RANK</a>
    </nav>
</Layout>

<style>
    .mc-wrap {
        max-width: 720px;
        margin: 0 auto;
        padding: 24px 20px 140px;
    }
    .mc-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 24px;
        gap: 16px;
    }
    .mc-brand__title {
        font-family: var(--font-display);
        text-transform: uppercase;
        font-size: clamp(36px, 8vw, 56px);
        line-height: 0.85;
        letter-spacing: -0.02em;
        margin: 0;
    }
    .mc-brand__sub {
        font-family: var(--font-body);
        font-size: 13px;
        opacity: 0.75;
        margin: 8px 0 0;
    }
    .mc-back {
        font-family: var(--font-display);
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 0.5px;
        color: var(--color-fg);
        text-decoration: none;
        background: var(--color-surface);
        border: var(--border);
        border-radius: var(--radius-pill);
        padding: 8px 14px;
    }

    .mc-hero { margin-bottom: 24px; }
    .mc-hero-card {
        padding: 28px 24px 24px;
    }
    .mc-hero-card__label {
        font-family: var(--font-display);
        text-transform: uppercase;
        font-size: 14px;
        letter-spacing: 0.05em;
        margin: 0;
    }
    .mc-hero-card__display {
        font-family: var(--font-display);
        text-transform: uppercase;
        font-size: clamp(56px, 14vw, 96px);
        line-height: 0.85;
        letter-spacing: -0.02em;
        margin: 8px 0 12px;
    }
    .mc-hero-card__detail {
        font-family: var(--font-body);
        font-size: 15px;
        line-height: 1.5;
        margin: 0 0 20px;
    }

    .mc-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 36px;
    }
    .mc-stat {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 16px 14px;
        min-height: 120px;
    }
    .mc-stat__label {
        font-family: var(--font-display);
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.05em;
        opacity: 0.85;
    }
    .mc-stat__value {
        font-family: var(--font-display);
        font-size: clamp(36px, 8vw, 56px);
        line-height: 0.9;
        letter-spacing: -0.02em;
    }

    .mc-events { display: grid; gap: 12px; margin-bottom: 36px; }
    .mc-event {
        display: grid;
        grid-template-columns: 60px 1fr auto;
        align-items: center;
        gap: 16px;
        padding: 14px 16px;
    }
    .mc-event__date {
        display: flex;
        flex-direction: column;
        align-items: center;
        font-family: var(--font-display);
        text-transform: uppercase;
    }
    .mc-event__date strong {
        font-size: 12px;
        letter-spacing: 0.05em;
    }
    .mc-event__date span {
        font-size: 32px;
        line-height: 0.9;
        letter-spacing: -0.02em;
    }
    .mc-event__title {
        font-family: var(--font-body);
        font-size: 17px;
        margin: 0 0 4px;
        font-weight: normal;
    }
    .mc-event__meta {
        font-family: var(--font-body);
        font-size: 13px;
        opacity: 0.75;
        margin: 0;
    }

    .mc-runners {
        display: grid;
        gap: 12px;
        margin-bottom: 32px;
    }
    .mc-runner {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        padding: 18px 16px;
    }
    .mc-runner__name {
        font-family: var(--font-body);
        font-size: 17px;
    }
    .mc-runner__stat {
        font-family: var(--font-display);
        font-size: 24px;
        text-transform: uppercase;
        letter-spacing: -0.01em;
    }

    .mc-cta { display: flex; justify-content: center; margin: 24px 0 32px; }

    .mc-footer {
        text-align: center;
        font-family: var(--font-body);
        font-size: 12px;
        margin-top: 24px;
        padding-top: 18px;
        border-top: var(--border);
    }
    .mc-footer__line { margin: 0; opacity: 0.85; }
    .mc-footer__built { margin: 8px 0 0; }
    .mc-footer__built a {
        color: var(--color-fg);
        text-decoration: none;
        font-family: var(--font-display);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 11px;
    }

    @media (max-width: 540px) {
        .mc-stats { grid-template-columns: 1fr 1fr; }
        .mc-stats .mc-stat:last-child { grid-column: 1 / -1; }
        .mc-event { grid-template-columns: 50px 1fr; }
        .mc-event > .hyp-badge { grid-column: 2 / 3; justify-self: start; }
    }
</style>

<script>
    if (typeof window !== "undefined") {
        (window as any).wardrobeTrack?.("wardrobe_demo_view", {
            system: "hyper",
            page: "marathon-club/index",
        });
    }
</script>
