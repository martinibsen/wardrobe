---
import Layout from "../../../layouts/Layout.astro";
import NodesignChrome from "../../../components/nodesign/NodesignChrome.astro";
---

<Layout
    title="Essence"
    description="Nodesign habitat — V O I D."
    system="nodesign"
    chrome="hidden"
>
    <NodesignChrome hideBrand={true}>
        <a class="nds-text nds-peripheral nds-magnetic nds-top-left" data-strength="20" href="/nodesign/essence/work">
            <span>Work</span>
        </a>
        <a class="nds-text nds-peripheral nds-magnetic nds-top-center" data-strength="20" href="/nodesign/essence">
            <span>Studio Architecture</span>
        </a>
        <a class="nds-text nds-peripheral nds-magnetic nds-top-right" data-strength="20" href="/nodesign/essence/about">
            <span>About</span>
        </a>

        <div class="nds-text nds-focal nds-focal--display nds-magnetic nds-center-absolute" data-strength="40">
            <span>V O I D</span>
        </div>

        <a class="nds-text nds-peripheral nds-magnetic" data-strength="20"
           style="bottom: var(--pad); left: var(--pad); top: auto;"
           href="/nodesign/essence/inquiry">
            <span>Inquiry</span>
        </a>
        <span class="nds-text nds-peripheral"
              style="bottom: var(--pad); right: var(--pad); top: auto; opacity: 0.4;">
            <span>2024</span>
        </span>
    </NodesignChrome>
</Layout>

<script>
    if (typeof window !== "undefined") {
        (window as any).wardrobeTrack?.("wardrobe_demo_view", {
            system: "nodesign",
            page: "home-void",
        });
    }
</script>
